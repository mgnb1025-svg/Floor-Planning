<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>TileArchitect AI Pro</title>
    <style>
        :root { --pro-gold: #d4af37; --ai-purple: #8a2be2; --success: #38a169; --error: #e53e3e; --bg: #1a202c; --card: #ffffff; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; display: flex; flex-direction: column; height: 100vh; background: var(--bg); color: #333; overflow: hidden; }
        
        /* Layout for Mobile & Desktop */
        @media (min-width: 768px) { body { flex-direction: row; } .sidebar { width: 380px; height: 100vh; } }
        
        .sidebar { background: var(--card); border-right: 1px solid #e2e8f0; overflow-y: auto; padding: 20px; flex-shrink: 0; box-sizing: border-box; }
        .viewport { flex-grow: 1; position: relative; background: #2d3748; display: flex; align-items: center; justify-content: center; }
        
        /* UI Components */
        .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; text-transform: uppercase; margin-bottom: 5px; }
        .badge-pro { background: #fffaf0; color: var(--pro-gold); border: 1px solid var(--pro-gold); }
        .badge-ai { background: #f3e5f5; color: var(--ai-purple); border: 1px solid var(--ai-purple); }
        
        section { border-bottom: 1px solid #edf2f7; padding: 15px 0; }
        h3 { font-size: 14px; color: #4a5568; margin: 0 0 10px 0; }
        input, select, button { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #cbd5e0; margin-bottom: 10px; font-size: 14px; box-sizing: border-box; }
        
        .btn-ai { background: var(--ai-purple); color: white; border: none; font-weight: bold; cursor: pointer; transition: opacity 0.2s; }
        .btn-pay { background: var(--success); color: white; border: none; font-weight: bold; cursor: pointer; }
        .btn-restore { background: none; border: none; color: #718096; text-decoration: underline; font-size: 12px; cursor: pointer; margin-top: 10px; }

        /* App Visuals */
        canvas { background: white; border-radius: 4px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); max-width: 90%; height: auto; transition: filter 0.3s; }
        .is-blurred canvas { filter: blur(15px); }
        .watermark { position: absolute; font-size: 40px; font-weight: 900; color: rgba(255,255,255,0.1); transform: rotate(-30deg); pointer-events: none; z-index: 5; text-align: center; }
        
        #ai-scanner { position: absolute; width: 100%; height: 3px; background: var(--ai-purple); box-shadow: 0 0 15px var(--ai-purple); top: 0; display: none; z-index: 10; }
        .status-box { font-size: 12px; background: #f7fafc; padding: 12px; border-radius: 6px; border-left: 4px solid var(--ai-purple); line-height: 1.4; }
    </style>
</head>
<body class="is-blurred" id="appBody">

<div class="sidebar">
    <header>
        <div id="tierBadge" class="badge">Demo Mode</div>
        <h1 style="margin:0; font-size: 20px;">TileArchitect <span style="color:var(--ai-purple)">AI</span></h1>
    </header>

    <section>
        <h3>📏 Step 1: Manual Specs</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
            <div><label style="font-size:10px">LENGTH (FT)</label><input type="number" id="roomL" value="12" oninput="calculate()"></div>
            <div><label style="font-size:10px">WIDTH (FT)</label><input type="number" id="roomW" value="10" oninput="calculate()"></div>
        </div>
        <label style="font-size:10px">WALL VARIANCE (INCHES)</label>
        <input type="number" id="variance" placeholder="0.25" oninput="calculate()">
    </section>

    <section id="wasteOptimizer" style="background: #fdf2f2; padding: 12px; border-radius: 8px; border: 1px solid #feb2b2;">
        <h3 style="color: #c53030; margin: 0;">📦 Waste Optimizer</h3>
        <div style="font-size: 14px; margin: 5px 0;">Order: <strong id="boxCount">0</strong> Boxes</div>
        <div id="complexityLabel" style="font-size: 11px; color: #718096;">Complexity: Low (7% waste)</div>
    </section>

    <section>
        <div class="badge badge-ai">AI Foreman</div>
        <button class="btn-ai" onclick="runScan()">✨ Scan & Fix Errors ($4.99)</button>
        <div id="aiResponse" class="status-box">Ready to scan room geometry...</div>
    </section>

    <section style="text-align: center;">
        <button class="btn-pay" onclick="unlock('one-time')">Unlock Blueprint (<span id="price">$0.00</span>)</button>
        <button class="btn-pay" style="background:var(--pro-gold); margin-top:8px;" onclick="unlock('pro')">Go PRO ($25/mo)</button>
        <button class="btn-restore" onclick="restore()">Restore Purchases</button>
    </section>
</div>

<div class="viewport">
    <div id="ai-scanner"></div>
    <div class="watermark" id="wmText">LOCKED<br>PURCHASE TO VIEW</div>
    <canvas id="gridCanvas" width="400" height="400"></canvas>
</div>

<script>
    const canvas = document.getElementById('gridCanvas');
    const ctx = canvas.getContext('2d');
    const appBody = document.getElementById('appBody');

    function calculate() {
        const l = parseFloat(document.getElementById('roomL').value) || 0;
        const w = parseFloat(document.getElementById('roomW').value) || 0;
        const v = parseFloat(document.getElementById('variance').value) || 0;
        const sqft = l * w;
        
        // Monetization Logic ($0.10/sqft)
        document.getElementById('price').innerText = "$" + (sqft * 0.10).toFixed(2);
        
        // Waste Logic
        let waste = 0.07;
        if(v > 0.5) { waste = 0.15; document.getElementById('complexityLabel').innerText = "Complexity: High (15% waste)"; }
        else { document.getElementById('complexityLabel').innerText = "Complexity: Low (7% waste)"; }
        
        const boxes = Math.ceil((sqft * (1 + waste)) / 22.5);
        document.getElementById('boxCount').innerText = boxes;
        
        drawGrid();
    }

    function drawGrid() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.strokeStyle = "#edf2f7";
        for(let i=0; i<canvas.width; i+=20) {
            for(let j=0; j<canvas.height; j+=20) { ctx.strokeRect(i, j, 20, 20); }
        }
        ctx.strokeStyle = "var(--bg)";
        ctx.lineWidth = 2;
        ctx.strokeRect(40, 40, 320, 320);
    }

    function runScan() {
        const s = document.getElementById('ai-scanner');
        s.style.display = 'block';
        let p = 0;
        const interval = setInterval(() => {
            p += 8;
            s.style.top = p + 'px';
            if(p > window.innerHeight) {
                clearInterval(interval);
                s.style.display = 'none';
                document.getElementById('aiResponse').innerHTML = "<strong>AI Fix:</strong> Wall variance detected. Offset starting row by 1/4\" to ensure visual symmetry.";
            }
        }, 20);
    }

    function unlock(tier) {
        alert("Redirecting to Stripe...");
        appBody.classList.remove('is-blurred');
        document.getElementById('wmText').style.display = 'none';
        const b = document.getElementById('tierBadge');
        b.innerText = tier === 'pro' ? 'PRO MEMBER' : 'PROJECT UNLOCKED';
        b.className = tier === 'pro' ? 'badge badge-pro' : 'badge';
        if(tier === 'pro') localStorage.setItem('isPro', 'true');
    }

    function restore() {
        if(localStorage.getItem('isPro')) unlock('pro');
        else alert("No previous purchases found.");
    }

    calculate();
</script>
</body>
</html>
